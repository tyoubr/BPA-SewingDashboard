@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <title>Sewing DHU Dashboard</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <style>
        html {
        font-size: clamp(12px, 1vw, 20px);
        }

        body {
            background-color: #0f172a;
            color: white;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        /* TITLE */
        h3 {
            text-align: center;
            padding: 5px;
            margin-bottom: 5px;
            font-weight: bold;
            font-size: clamp(16px, 2vw, 32px);
        }
        #selectionInfo {
            font-size: clamp(12px, 1.2vw, 18px);
            font-weight: bold;
            color: #facc15;
            text-align: center;
            margin-bottom: 20px;
            display: none;
        }

        /* CARD */
        .dashboard-card {
            background: #1e293b;
            border-radius: 10px;
            padding: 5px;
            text-align: center;
            height: 100%;
        }
            .dashboard-card h2 {
                font-size: 30px !important;
                font-weight: bold;
                color: #facc15;
                padding: 5px;
            }


        .dashboard-card p {
            font-size: clamp(10px, 1.2vw, 16px);
            font-weight: bold;
        }

        /* CARD GRID AUTO FIT */
        .row.g-3 > div {
            flex: 1 1 calc(12.5% - 10px);
            min-width: 120px;
        }

        /* CHART BOX */
        .chart-box {
            background: white;
            border-radius: 10px;
            padding: 10px;
            height: 50vh;   /* 🔥 key responsive height */
            min-height: 250px;
        }

        /* CHART FIX */
        canvas {
            width: 100% !important;
            height: 100% !important;
        }

        /* FILTER BUTTON */
        #filterToggleBtn {
            position: fixed;
            top: 10px;
            right: 15px;
            z-index: 1050;
            font-size: clamp(10px, 1vw, 16px);
        }

        /* LOADING */
        #loadingOverlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.5);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 9999;
        }

        @@media (min-width: 1600px) {
        .chart-box {height: 60vh;}
        .dashboard-card h2 {font-size: 2vw;}
        }
    </style>

</head>

<body data-companyid="@ViewBag.CompanyId"
      data-floorid="@ViewBag.FloorId"
        data-date="@ViewBag.Date">

    <!-- LOADING -->
    <div id="loadingOverlay">
        <div class="text-center text-white">
            <div class="spinner-border text-warning"></div>
            <div style="font-size:24px;margin-top:10px;">Loading...</div>
        </div>
    </div>


    <div class="container-fluid">

        <!-- TITLE -->
        <h3>Line Performance Board</h3>

        <!-- COMPANY + FLOOR -->
        <div id="selectionInfo">
            Company: <span id="selectedCompany"></span> |
            Floor: <span id="selectedFloorText"></span> |
            Date: <span id="selectedDateText"></span>
        </div>


        <!-- CARDS -->
        <div class="row g-3 mb-4">

            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                <div class="dashboard-card">
                    <h2 id="inputQty">0</h2>
                    <p>Sewing Input</p>
                </div>
            </div>

            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                <div class="dashboard-card">
                    <h2 id="checkQty">0</h2>
                    <p>Check Qty</p>
                </div>
            </div>

            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                <div class="dashboard-card">
                    <h2 id="alterSpotQty">0</h2>
                    <p>Alter/Spot Qty</p>
                </div>
            </div>

            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                <div class="dashboard-card">
                    <h2 id="replaceQty">0</h2>
                    <p>Replace Qty</p>
                </div>
            </div>

            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                <div class="dashboard-card">
                    <h2 id="rejectQty">0</h2>
                    <p>Reject Qty</p>
                </div>
            </div>

            @* <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                <div class="dashboard-card">
                    <h2 id="rejectPoint">0</h2>
                    <p>Reject Point</p>
                </div>
            </div> *@

            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                <div class="dashboard-card">
                    <h2 id="outputQty">0</h2>
                    <p>Output Qty</p>
                </div>
            </div>

            <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                <div class="dashboard-card">
                    <h2 id="dhu">0</h2>
                    <p>DHU %</p>
                </div>
            </div>

        </div>


        <!-- CHARTS -->

        <div class="row g-4">

            <div class="col-md-8">
                <div class="chart-box">
                    <canvas id="barChart"></canvas>
                </div>
            </div>

            <div class="col-md-4">
                <div class="chart-box">
                    <canvas id="pieChart"></canvas>
                </div>
            </div>

        </div>

    </div>


    <!-- FILTER BUTTON -->

    <button class="btn btn-warning fw-bold"
            id="filterToggleBtn"
            data-bs-toggle="offcanvas"
            data-bs-target="#filterPanel">
        ☰ Filter
    </button>


    <!-- FILTER PANEL -->

    <div class="offcanvas offcanvas-end text-bg-dark" id="filterPanel">

        <div class="offcanvas-header">
            <h5>Dashboard Filters</h5>
        </div>

        <div class="offcanvas-body">

            <div class="mb-3">
                <label class="form-label fw-bold">Select Company</label>
                <select id="companySelect" class="form-select">
                    <option value="">Select Company</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Select Floor</label>
                <select id="floorSelect" class="form-select">
                    <option value="">Select Floor</option>
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label fw-bold">Select Date</label>
                <input type="date" id="dateSelect" class="form-control" />
            </div>

            <button id="btnLoadDashboard"
                    class="btn btn-warning w-100 fw-bold">
                Load Dashboard
            </button>

        </div>

    </div>


    <!-- SCRIPTS -->
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2"></script>
    <script src="~/js/dBoard.js"></script>


