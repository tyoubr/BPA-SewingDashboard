<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sewing Dashboard</title>

<style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        width: 100%;
    }

    iframe {
        width: 100%;
        height: 100%;
        border: none;
    }
</style>
</head>

<body>

<iframe id="siteFrame"></iframe>

<script>
window.alert = function () { };

// =====================
// STATE
// =====================
let isAbc = true;

let companyId = null;
let floorId = null;

// =====================
// URL PARAMS
// =====================
const params = new URLSearchParams(window.location.search);

companyId = params.get("companyId") || "@ViewBag.CompanyId";
floorId = params.get("floorId") || "@ViewBag.FloorId";

// =====================
// DATE
// =====================
function getCurrentDate() {
    const d = new Date();
    return `${String(d.getDate()).padStart(2,'0')}-${String(d.getMonth()+1).padStart(2,'0')}-${d.getFullYear()}`;
}

// =====================
// CACHE SAFE URLS
// =====================
function getAbcUrl() {
    return "http://180.92.235.190:8022/erp/production/reports/display_board_nrg_new.php"
        + "?action=report_generate"
        + "&cbo_company_name=" + companyId
        + "&txt_date=" + getCurrentDate()
        + "&cbo_floor_id=" + floorId
        + "&page_width=1536"
        + "&page_height=864"
        + "&t=" + Date.now();
}
function getXyzUrl() {
            return "http://103.9.134.216/Dashboard/Index"
        + "?companyId=" + companyId
        + "&floorId=" + floorId
        + "&date=" + getCurrentDate()
        + "&t=" + Date.now();
}

// =====================
// FORCE FULL RESET LOAD
// =====================
function loadIframe(url) {
    const iframe = document.getElementById("siteFrame");

    // 🔥 HARD RESET (IMPORTANT FIX)
    iframe.src = "about:blank";

    setTimeout(() => {
        iframe.src = url;
    }, 500);
}

// =====================
// SWITCH
// =====================
function switchIframeSource() {
    const url = isAbc ? getAbcUrl() : getXyzUrl();

    console.log("Loading iframe:", url);

    loadIframe(url);

    isAbc = !isAbc;
}

// =====================
// INIT
// =====================
switchIframeSource();

// 3 minute refresh
setInterval(switchIframeSource, 180000);

</script>

</body>
</html>


