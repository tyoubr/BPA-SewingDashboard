<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sewing Dashboard</title>

<style>
    html, body {
        margin: 0;
        padding: 0;
        height: 100%;
        width: 100%;
        overflow: hidden;
        background: black;
    }

    iframe {
        width: 100%;
        height: 100%;
        border: none;
    }
</style>
</head>

<body>

<iframe id="siteFrame"></iframe>

<script>

// =====================
// STATE
// =====================
let isDashboard = true;

// =====================
// PARAMS
// =====================
const params = new URLSearchParams(window.location.search);

const companyId = params.get("companyId") || 3;
const floorId = params.get("floorId") || 1;

// =====================
// DATE
// =====================
function getCurrentDate() {
    const d = new Date();
    return `${String(d.getDate()).padStart(2,'0')}-${String(d.getMonth()+1).padStart(2,'0')}-${d.getFullYear()}`;
}

// =====================
// DASHBOARD (LOCAL .NET PAGE)
// =====================
function getDashboardUrl() {
    return `/Dashboard/Index`
        + `?companyId=${companyId}`
        + `&floorId=${floorId}`
        + `&t=${Date.now()}`;
}

// =====================
// PHP VIA .NET PROXY (IMPORTANT)
// =====================
function getPhpUrl() {
    return `/Proxy/PhpDashboard`
        + `?companyId=${companyId}`
        + `&floorId=${floorId}`
        + `&t=${Date.now()}`;
}

// =====================
// LOAD IFRAME (SAFE)
// =====================
function loadIframe(url) {
    const iframe = document.getElementById("siteFrame");

    console.log("Loading:", url);

    iframe.src = url;
}

// =====================
// SWITCH LOGIC
// =====================
function switchDashboard() {
    const url = isDashboard ? getDashboardUrl() : getPhpUrl();

    loadIframe(url);

    isDashboard = !isDashboard;
}

// =====================
// INIT
// =====================
switchDashboard();

// =====================
// AUTO ROTATE (2 MIN)
// =====================
setInterval(switchDashboard, 120000);

</script>

</body>
</html>